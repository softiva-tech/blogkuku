# Vercel production environment template
# Add these in Vercel: Project -> Settings -> Environment Variables

# MySQL connection for your hosted DB (NOT local XAMPP root)
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"

# Required for NextAuth/Auth.js (min 32 chars)
AUTH_SECRET="REPLACE_WITH_OPENSSL_BASE64_32_CHAR_SECRET"

# Public site URL
NEXTAUTH_URL="https://your-domain.com"

# Optional seed/admin defaults
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-after-first-login"

# Optional payment keys
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# PAYTM_MERCHANT_ID=
# PAYTM_MERCHANT_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
