# Production / VPS — copy to `.env` next to `server.js` or set in the host panel.
# Database: Supabase (PostgreSQL). Do not use mysql:// here.

NODE_ENV=production

# Supabase → Project Settings → Database → copy “URI” (postgresql://…)
# Optional: set SUPABASE_DATABASE_URL to the same value if your panel names it that way.
# Direct: host db.cekdpuuyfhwjmlewitjq.supabase.co, port 5432, database postgres, user postgres
# Password special chars must be URL-encoded in the URI (@ → %40, # → %23).
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.cekdpuuyfhwjmlewitjq.supabase.co:5432/postgres?sslmode=require"

# Optional (Supabase JS / dashboard); Prisma-only deploys can omit.
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Required — NextAuth / Auth.js (min 32 characters)
# Generate: openssl rand -base64 32
AUTH_SECRET="PASTE_A_SECRET_AT_LEAST_32_CHARS_LONG_HERE"

# Required — site origin only: https + domain, no path
NEXTAUTH_URL="https://yourdomain.com"

PORT=3000

# Do not set HOSTNAME unless you understand Next.js binding. Use ./start.sh (dist)
# or HOSTNAME=0.0.0.0 — a wrong HOSTNAME often causes 503 behind nginx/apache.

# --- prisma seed (npm run db:seed) — demo admin; change in production ---
# ADMIN_EMAIL="admin@demo.com"
# ADMIN_PASSWORD="admin123"

# --- Payment gateways (optional; toggles in Admin → Settings) ---
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# PAYTM_MERCHANT_ID=
# PAYTM_MERCHANT_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
