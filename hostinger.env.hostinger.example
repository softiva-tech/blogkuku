# Hostinger / production — copy this file to `.env` next to `server.js`
# (after upload or in Git deploy env vars). Do not commit a filled `.env`.
#
# hPanel → Databases → MySQL: create DB + user; use that user (not root).
# Password special chars must be URL-encoded (@ → %40, # → %23, etc.).

NODE_ENV=production

# Required — Prisma / MySQL
DATABASE_URL="mysql://PANEL_USER:ENCODED_PASSWORD@127.0.0.1:3306/PANEL_DB_NAME"

# Required — NextAuth / Auth.js (min 32 characters)
# Generate: openssl rand -base64 32
AUTH_SECRET="PASTE_A_SECRET_AT_LEAST_32_CHARS_LONG_HERE"

# Required — full URL with https:// (not just the domain), no trailing slash
NEXTAUTH_URL="https://yourdomain.com"

# If your reverse proxy expects a fixed port (optional; default often 3000)
# PORT=3000

# --- Only when running `npx prisma db seed` (optional) ---
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="change-me-after-first-login"

# --- Payment gateways (optional; toggles in Admin → Settings) ---
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# PAYTM_MERCHANT_ID=
# PAYTM_MERCHANT_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
