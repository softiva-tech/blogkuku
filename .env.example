# Supabase (PostgreSQL) — Project Settings → Database → Connection string → URI
# Use Session mode for serverless; add ?sslmode=require if your client needs it (often in the URI already).
#
# Example (password with special chars must be URL-encoded in the URI):
# DATABASE_URL="postgresql://postgres.[ref]:YOUR_PASSWORD@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Optional alias if your host only allows one “Supabase” variable name:
# SUPABASE_DATABASE_URL="postgresql://..."

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Optional — only if you use the Supabase JS client or dashboard features that need the public URL/key.
# This app works with Prisma + DATABASE_URL alone; do not commit real keys.
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Required in production: min 32 chars. Generate: openssl rand -base64 32
AUTH_SECRET=""

# Used only by prisma/seed.ts for the default admin account
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-after-first-login"

NEXTAUTH_URL="http://localhost:3000"

# --- Payment gateways (optional; enable toggles in Admin → Settings) ---
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# PAYTM_MERCHANT_ID=
# PAYTM_MERCHANT_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
