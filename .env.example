# --- XAMPP MySQL (Windows/macOS) ---
# 1. Start MySQL in XAMPP
# 2. Create DB: import scripts/mysql/01-create-database.sql in phpMyAdmin (SQL tab),
#    or run: ./scripts/create-mysql-db.sh  (needs mysql CLI on PATH)
# 3. Apply Prisma schema + seed: npm run db:setup
# 4. Default user root, empty password:
DATABASE_URL="mysql://root:@127.0.0.1:3306/blogkuku"
# With password:
# DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/blogkuku"

# --- PostgreSQL (if you switch prisma/schema.prisma provider back to postgresql) ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Required in production: min 32 chars. Generate: openssl rand -base64 32
# (NEXTAUTH_SECRET is accepted as an alias.)
AUTH_SECRET=""

# Used only by prisma/seed.ts for the default admin account
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-after-first-login"

NEXTAUTH_URL="http://localhost:3000"

# --- Payment gateways (optional; enable toggles in Admin → Settings) ---
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# PAYTM_MERCHANT_ID=
# PAYTM_MERCHANT_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
